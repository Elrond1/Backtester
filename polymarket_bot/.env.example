# Скопируй в .env и заполни реальными значениями

# Приватный ключ Metamask / кошелька Polygon (0x...)
POLY_PRIVATE_KEY=0x...

# L2 API ключи (опционально, для более быстрого auth)
# Получить на: https://clob.polymarket.com/auth/api-key
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Режим без реальных ордеров (true/false)
DRY_RUN=true

# Уровень логов: DEBUG / INFO / WARNING
LOG_LEVEL=INFO
